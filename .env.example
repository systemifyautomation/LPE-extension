# ─────────────────────────────────────────────
# LPE Extension — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# ── Google OAuth 2.0 ─────────────────────────
# Create at: https://console.cloud.google.com
# Type: Desktop application (enables PKCE — no client secret needed)
PLASMO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── n8n Backend ──────────────────────────────
# Base URL of your n8n instance  (no trailing slash)
PLASMO_PUBLIC_N8N_BASE_URL=https://your-n8n-instance.com

# n8n webhook token for authorizing requests from the extension
PLASMO_PUBLIC_N8N_WEBHOOK_TOKEN=your_webhook_token_here
