{
  "manifest_version": 3,
  "name": "Voice Auto-fill",
  "version": "1.0.0",
  "description": "Voice-to-text for any input field — transcribed by OpenAI Whisper",

  "permissions": ["storage"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Voice Auto-fill — Settings"
  }
}
