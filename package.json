{
  "name": "lpe-voice-input",
  "displayName": "LPE Voice Input",
  "description": "Add a voice recording button to any text input — audio is transcribed via your n8n webhook and inserted at the cursor.",
  "version": "0.1.0",
  "publisher": "lpe",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lpe-voice-input.startRecording",
        "title": "Voice Input: Start Recording",
        "icon": "$(mic)"
      },
      {
        "command": "lpe-voice-input.configure",
        "title": "Voice Input: Configure Webhook URL"
      }
    ],
    "keybindings": [
      {
        "command": "lpe-voice-input.startRecording",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v"
      }
    ],
    "configuration": {
      "title": "LPE Voice Input",
      "properties": {
        "lpeVoiceInput.webhookUrl": {
          "type": "string",
          "default": "",
          "description": "n8n webhook URL that receives the audio and returns a transcription. The webhook should accept POST with JSON body { audio: string (base64), mimeType: string } and respond with JSON { transcription: string }."
        },
        "lpeVoiceInput.insertTarget": {
          "type": "string",
          "default": "editor",
          "enum": [
            "editor",
            "clipboard"
          ],
          "enumDescriptions": [
            "Insert transcription at the active editor cursor position.",
            "Copy transcription to clipboard (use when working in other input fields)."
          ],
          "description": "Where to place the transcription result."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.1.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
