{
  "name": "lpe-extension",
  "displayName": "LPE Extension",
  "version": "0.1.0",
  "description": "LPE — M&A legal intelligence powered by n8n. Works across all browsers and Google Workspace.",
  "author": "LPE",
  "scripts": {
    "setup": "node scripts/generate-icon.js",
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv2",
    "dev:edge": "plasmo dev --target=edge-mv3",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "build:edge": "plasmo build --target=edge-mv3",
    "build:all": "npm run build && npm run build:firefox && npm run build:edge",
    "package": "plasmo package",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@parcel/watcher-win32-x64": "^2.5.6",
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.12.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.364.0",
    "plasmo": "^0.89.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*.google.com/*",
      "https://oauth2.googleapis.com/*",
      "https://www.googleapis.com/*"
    ],
    "permissions": [
      "identity",
      "storage",
      "tabs",
      "activeTab",
      "scripting",
      "alarms"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
    }
  }
}
